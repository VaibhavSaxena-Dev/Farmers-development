# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/farm-management?retryWrites=true&w=majority

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=5002
CLIENT_ORIGIN=http://localhost:8080

# Voice Service Configuration
VOICE_ENABLED=true
NOTIFICATION_ENABLED=true

# Disease Alert System
DISEASE_ALERT_ENABLED=true
ALERT_RADIUS_KM=50

# Google Maps (Find Nearby Vet page - frontend only, use .env in frontend folder)
# Get key: https://console.cloud.google.com/apis/library → enable Maps JavaScript API + Places API
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
